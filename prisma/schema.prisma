generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id        String   @id @default(uuid())
  date      DateTime
  users     User[]
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id])
}

model Message {
  id    String @id @default(uuid())
  text  String
  event Event?
}

model User {
  id        String  @id @default(uuid())
  name      String
  cellphone String
  events    Event[]
}
